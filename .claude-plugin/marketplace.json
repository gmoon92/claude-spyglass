{
  "name": "spyglass-local",
  "owner": { "name": "gmoon" },
  "plugins": [
    {
      "name": "typescript-lsp",
      "source": "./.claude-plugin/typescript-lsp",
      "strict": false,
      "lspServers": {
        "typescript": {
          "command": "typescript-language-server",
          "args": ["--stdio"],
          "extensionToLanguage": {
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".js": "javascript",
            ".jsx": "javascriptreact"
          }
        }
      }
    }
  ]
}
