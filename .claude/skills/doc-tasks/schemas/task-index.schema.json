{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-index.schema.json",
  "title": "Task Index",
  "description": "feature 단위 태스크 인덱스 파일 (task.json). 전체 상태 요약과 개별 태스크 파일 경로를 관리합니다.",
  "type": "object",
  "required": ["feature", "title", "docs", "created", "updated", "summary", "tasks"],
  "additionalProperties": false,
  "properties": {
    "feature": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "기능 식별자 (kebab-case)"
    },
    "title": {
      "type": "string",
      "description": "기능 전체 제목"
    },
    "docs": {
      "type": "object",
      "required": ["plan", "adr"],
      "additionalProperties": false,
      "properties": {
        "plan": { "type": "string", "description": "계획 문서 경로 (상대)" },
        "adr":  { "type": "string", "description": "ADR 문서 경로 (상대)" }
      }
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "생성일 (YYYY-MM-DD)"
    },
    "updated": {
      "type": "string",
      "format": "date",
      "description": "마지막 상태 갱신일 (YYYY-MM-DD)"
    },
    "summary": {
      "type": "object",
      "required": ["total", "pending", "in_progress", "done", "skipped"],
      "additionalProperties": false,
      "properties": {
        "total":       { "type": "integer", "minimum": 0 },
        "pending":     { "type": "integer", "minimum": 0 },
        "in_progress": { "type": "integer", "minimum": 0 },
        "done":        { "type": "integer", "minimum": 0 },
        "skipped":     { "type": "integer", "minimum": 0 }
      }
    },
    "parallel_groups": {
      "type": "array",
      "description": "병렬 실행 가능한 태스크 그룹 목록",
      "items": {
        "type": "object",
        "required": ["group", "tasks"],
        "additionalProperties": false,
        "properties": {
          "group":       { "type": "string", "description": "그룹 식별자 (kebab-case)" },
          "description": { "type": "string", "description": "병렬 가능 이유" },
          "tasks": {
            "type": "array",
            "items": { "type": "string", "pattern": "^T-[0-9]+[a-z]?$" },
            "minItems": 2
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "description": "전체 태스크 목록 (요약 정보만 포함, 세부는 file 경로 참조)",
      "items": {
        "type": "object",
        "required": ["id", "title", "file", "status", "type", "phase", "risk", "depends_on", "parallel_with"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^T-[0-9]+[a-z]?$",
            "description": "태스크 ID (예: T-01, T-09a)"
          },
          "title": { "type": "string" },
          "file": {
            "type": "string",
            "pattern": "^tasks/task-[0-9]+[a-z]?\\.json$",
            "description": "세부 태스크 파일 경로 (상대)"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "skipped"]
          },
          "type": {
            "type": "string",
            "enum": ["test", "refactor", "feat", "fix", "docs"]
          },
          "phase": {
            "type": "integer",
            "minimum": 0,
            "description": "실행 단계 번호"
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "pattern": "^T-[0-9]+[a-z]?$" },
            "description": "선행 태스크 ID 목록"
          },
          "parallel_with": {
            "type": "array",
            "items": { "type": "string", "pattern": "^T-[0-9]+[a-z]?$" },
            "description": "동시 실행 가능한 태스크 ID 목록"
          }
        }
      }
    }
  }
}
